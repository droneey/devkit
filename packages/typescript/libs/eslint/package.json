{
  "name": "@droneey/devkit-ts-eslint",
  "version": "1.0.3",
  "description": "Shared ESLint configuration with composable layers for base, environments, and frameworks.",
  "keywords": [
    "codestyle",
    "config",
    "eslint",
    "eslint-config",
    "lint",
    "linter",
    "linting",
    "nestjs",
    "quality",
    "react",
    "react-native",
    "shared"
  ],
  "homepage": "https://github.com/droneey/devkit/blob/main/packages/typescript/libs/eslint#readme",
  "bugs": {
    "url": "https://github.com/droneey/devkit/issues"
  },
  "license": "MIT",
  "author": {
    "name": "Dmytro Kurovskyi",
    "url": "https://kurovskyi.dev"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/droneey/devkit.git",
    "directory": "packages/typescript/libs/eslint"
  },
  "type": "module",
  "main": "index.ts",
  "module": "index.ts",
  "publishConfig": {
    "main": "dist/index.js",
    "module": "dist/index.js",
    "exports": {
      ".": {
        "import": "./dist/index.js"
      }
    }
  },
  "scripts": {
    "build": "rimraf dist && bun build --target=node --packages=external ./index.ts --outdir dist"
  },
  "files": [
    "dist/*"
  ],
  "devDependencies": {
    "@eslint/compat": "^2.0.3",
    "@eslint/js": "^10.0.1",
    "@types/bun": "^1.3.11",
    "@types/eslint-plugin-jsx-a11y": "^6.10.1",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-no-secrets": "^2.3.3",
    "eslint-plugin-perfectionist": "^4.15.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-native": "^5.0.0",
    "eslint-plugin-unicorn": "^63.0.0",
    "globals": "^17.4.0",
    "jiti": "^2.6.1",
    "rimraf": "^6.1.3",
    "typescript-eslint": "^8.57.1"
  },
  "peerDependencies": {
    "eslint": "^10.0.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-native": "^5.0.0",
    "typescript": "^5"
  },
  "peerDependenciesMeta": {
    "eslint-plugin-react": {
      "optional": true
    },
    "eslint-plugin-react-hooks": {
      "optional": true
    },
    "eslint-plugin-react-native": {
      "optional": true
    },
    "eslint-plugin-jsx-a11y": {
      "optional": true
    }
  }
}
