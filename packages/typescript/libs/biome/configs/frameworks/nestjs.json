{
  "$schema": "https://biomejs.dev/schemas/2.4.11/schema.json",
  "overrides": [
    {
      "includes": [
        "**/*.ts"
      ],
      "linter": {
        "rules": {
          "style": {
            "noParameterProperties": "off"
          },
          "suspicious": {
            "noEmptyBlockStatements": "off"
          },
          "complexity": {
            "noStaticOnlyClass": "off"
          }
        }
      }
    }
  ]
}
