{
  "name": "@droneey/devkit-ts-jest",
  "version": "1.0.2",
  "description": "Shared Jest configuration with base and e2e presets.",
  "keywords": [
    "config",
    "jest",
    "jest-config",
    "shared",
    "testing"
  ],
  "homepage": "https://github.com/droneey/devkit/blob/main/packages/typescript/libs/jest#readme",
  "bugs": {
    "url": "https://github.com/droneey/devkit/issues"
  },
  "license": "MIT",
  "author": {
    "name": "Dmytro Kurovskyi",
    "url": "https://kurovskyi.dev"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/droneey/devkit.git",
    "directory": "packages/typescript/libs/jest"
  },
  "type": "module",
  "main": "index.ts",
  "module": "index.ts",
  "types": "dist/index.d.ts",
  "publishConfig": {
    "main": "dist/index.js",
    "types": "dist/index.d.ts"
  },
  "scripts": {
    "build": "rimraf dist && bun build --target=node ./index.ts --outdir dist && bun run build:declaration",
    "build:declaration": "tsc --emitDeclarationOnly --project tsconfig.types.json --outdir dist && rimraf tsconfig.types.tsbuildinfo"
  },
  "files": [
    "dist/*"
  ],
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "rimraf": "^6.1.3"
  },
  "peerDependencies": {
    "jest": ">=29.0.0",
    "ts-jest": ">=29.0.0",
    "typescript": "^5"
  }
}
