{
  "name": "@droneey/devkit-ts-jest",
  "version": "1.4.1",
  "description": "Shared Jest configuration with base and e2e presets.",
  "keywords": [
    "config",
    "jest",
    "jest-config",
    "shared",
    "testing"
  ],
  "homepage": "https://github.com/droneey/devkit/blob/main/packages/typescript/libs/jest#readme",
  "bugs": {
    "url": "https://github.com/droneey/devkit/issues"
  },
  "license": "MIT",
  "author": {
    "name": "Dmytro Kurovskyi",
    "url": "https://kurovskyi.dev"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/droneey/devkit.git",
    "directory": "packages/typescript/libs/jest"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./preset": "./jest-preset.js",
    "./e2e": "./e2e/jest-preset.js"
  },
  "scripts": {
    "build": "rimraf dist && bun build --target=node --packages=external ./index.ts --outdir dist && cp index.d.ts dist/index.d.ts",
    "prepublishOnly": "bun run build"
  },
  "files": [
    "dist/*",
    "jest-preset.js",
    "e2e"
  ],
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "rimraf": "^6.1.3"
  },
  "peerDependencies": {
    "jest": ">=29.0.0",
    "ts-jest": ">=29.0.0",
    "typescript": "^5"
  }
}
