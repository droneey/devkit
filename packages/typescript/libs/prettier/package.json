{
  "name": "@droneey/devkit-ts-prettier",
  "version": "1.0.0",
  "description": "Shared Prettier configuration for consistent code formatting across projects.",
  "keywords": [
    "codestyle",
    "config",
    "formatter",
    "prettier",
    "prettier-config",
    "shared"
  ],
  "homepage": "https://github.com/droneey/devkit/blob/main/packages/typescript/libs/prettier#readme",
  "bugs": {
    "url": "https://github.com/droneey/devkit/issues"
  },
  "license": "MIT",
  "author": {
    "name": "Dmytro Kurovskyi",
    "url": "https://kurovskyi.dev"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/droneey/devkit.git",
    "directory": "packages/typescript/libs/prettier"
  },
  "type": "module",
  "main": "index.ts",
  "module": "index.ts",
  "types": "dist/index.d.ts",
  "publishConfig": {
    "main": "dist/index.js",
    "types": "dist/index.d.ts"
  },
  "scripts": {
    "build": "rimraf dist && bun build --target=node ./index.ts --outdir dist && bun run build:declaration",
    "build:declaration": "tsc --emitDeclarationOnly --project tsconfig.types.json --outdir dist && rimraf tsconfig.types.tsbuildinfo"
  },
  "files": [
    "dist/*"
  ],
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3"
  },
  "peerDependencies": {
    "prettier": ">=3.0.0",
    "typescript": "^5"
  }
}
