{
  "name": "@droneey/devkit-ts-lint-staged",
  "version": "1.1.1",
  "description": "Shared lint-staged configuration for running linters on staged files.",
  "keywords": [
    "config",
    "git",
    "lint-staged",
    "lint-staged-config",
    "pre-commit",
    "shared"
  ],
  "homepage": "https://github.com/droneey/devkit/blob/main/packages/typescript/libs/lint-staged#readme",
  "bugs": {
    "url": "https://github.com/droneey/devkit/issues"
  },
  "license": "MIT",
  "author": {
    "name": "Dmytro Kurovskyi",
    "url": "https://kurovskyi.dev"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/droneey/devkit.git",
    "directory": "packages/typescript/libs/lint-staged"
  },
  "type": "module",
  "main": "index.ts",
  "module": "index.ts",
  "types": "dist/index.d.ts",
  "publishConfig": {
    "main": "dist/index.js",
    "module": "dist/index.js",
    "types": "dist/index.d.ts",
    "exports": {
      ".": {
        "import": "./dist/index.js",
        "types": "./dist/index.d.ts"
      }
    }
  },
  "scripts": {
    "build": "rimraf dist && bun build --target=node ./index.ts --outdir dist && bun run build:declaration",
    "build:declaration": "tsc --emitDeclarationOnly --project tsconfig.types.json --outdir dist && rimraf tsconfig.types.tsbuildinfo"
  },
  "files": [
    "dist/*"
  ],
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "rimraf": "^6.1.3"
  },
  "peerDependencies": {
    "lint-staged": ">=16.0.0",
    "typescript": "^5"
  }
}
