{
  "name": "@droneey/devkit-ts-commitlint",
  "version": "1.0.0",
  "description": "Shared Commitlint configuration for consistent GIT commits across projects.",
  "keywords": [
    "commit",
    "commitlint",
    "commitlint-config",
    "config",
    "git",
    "shared"
  ],
  "homepage": "https://github.com/droneey/devkit/blob/main/packages/typescript/libs/commitlint#readme",
  "bugs": {
    "url": "https://github.com/droneey/devkit/issues"
  },
  "license": "MIT",
  "author": {
    "name": "Dmytro Kurovskyi",
    "url": "https://kurovskyi.dev"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/droneey/devkit.git",
    "directory": "packages/typescript/libs/commitlint"
  },
  "type": "module",
  "main": "index.ts",
  "module": "index.ts",
  "types": "dist/index.d.ts",
  "publishConfig": {
    "main": "dist/index.js",
    "types": "dist/index.d.ts"
  },
  "scripts": {
    "build": "bun build --target=node ./index.ts --outdir dist && bun run build:declaration",
    "build:declaration": "tsc --emitDeclarationOnly --project tsconfig.types.json --outdir dist",
    "postbuild": "rimraf tsconfig.types.tsbuildinfo"
  },
  "files": [
    "dist/*"
  ],
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@commitlint/types": "^20.5.0",
    "@types/bun": "^1.3.11",
    "rimraf": "^6.1.3"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
