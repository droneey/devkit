{
  "name": "@droneey/devkit-ts-eslint-biome",
  "version": "1.3.5",
  "description": "Lean ESLint config for Biome projects — type-checked rules only.",
  "keywords": [
    "biome",
    "config",
    "eslint",
    "eslint-config",
    "lint",
    "type-checked",
    "typescript"
  ],
  "homepage": "https://github.com/droneey/devkit/blob/main/packages/typescript/libs/eslint-biome#readme",
  "bugs": {
    "url": "https://github.com/droneey/devkit/issues"
  },
  "license": "MIT",
  "author": {
    "name": "Dmytro Kurovskyi",
    "url": "https://kurovskyi.dev"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/droneey/devkit.git",
    "directory": "packages/typescript/libs/eslint-biome"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "rimraf dist && bun build --target=node --packages=external ./index.ts --outdir dist && cp index.d.ts dist/index.d.ts",
    "prepublishOnly": "bun run build"
  },
  "files": [
    "dist/*"
  ],
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "eslint": "^10.1.0",
    "eslint-plugin-react-native": "^5.0.0",
    "rimraf": "^6.1.3",
    "typescript-eslint": "^8.57.1"
  },
  "dependencies": {
    "@eslint/compat": "^2.0.3",
    "globals": "^17.4.0"
  },
  "peerDependencies": {
    "eslint": "^10.0.0",
    "eslint-plugin-react-native": "^5.0.0",
    "typescript": "^5",
    "typescript-eslint": "^8.0.0"
  },
  "peerDependenciesMeta": {
    "eslint-plugin-react-native": {
      "optional": true
    }
  }
}
